#!/usr/bin/make -f
export PYBUILD_NAME = bups
export DH_VERBOSE = 1

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	dh_auto_build
	for f in locale/*/LC_MESSAGES/bups.po; do \
	    msgfmt "$$f" -o "$${f%.po}.mo"; \
	done

execute_after_dh_install:
	install -Dm644 bin/bups.desktop \
	    debian/bups/usr/share/applications/bups.desktop
	for lang in de es fr; do \
	    install -Dm644 locale/$$lang/LC_MESSAGES/bups.mo \
	        debian/bups/usr/share/locale/$$lang/LC_MESSAGES/bups.mo; \
	done
